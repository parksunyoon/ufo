<%- include('../layouts/header') %>

<div class="project-detail-container">
  <div class="project-content">
    <!-- 왼쪽: 이미지 -->
    <div class="image-section">
      <div class="main-image">
        <img src="/images/projects/<%= project.image %>" alt="<%= project.title %>">
      </div>

      <div class="additional-images">
        <% if (project.details && Array.isArray(project.details.images) && project.details.images.length) { %>
          <% project.details.images.forEach(function(img){ %>
            <div class="image-item">
              <img src="/images/projects/<%= img %>" alt="<%= project.title %>">
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- 오른쪽: 정보/설명 -->
    <div class="content-section">
      <div class="project-info">
        <h2><%= project.title %></h2>
        <p class="year"><%= project.year %></p>
      </div>

      <!-- 1) 진행중 타입: details.status가 있으면 진행중 블록 -->
      <% if (project.details && project.details.status) { %>
        <div class="ongoing-project">
          <div class="status"><%= project.details.status %></div>
          <div class="participation">
            <% if (project.details.participation) { %>
              <% Object.values(project.details.participation).forEach(function(line){ %>
                <p><%= line %></p>
              <% }) %>
            <% } %>
          </div>
        </div>

      <!-- 2) 학술/설명 배열 타입: details.description이 배열이면 각각 출력 -->
      <% } else if (project.details && Array.isArray(project.details.description)) { %>
        <div class="project-description">
          <% project.details.description.forEach(function(desc){ %>
            <p><%= desc %></p>
          <% }) %>
        </div>

      <!-- 3) 문자열 설명: details.description이 문자열이거나, 상단 project.description 하나만 있는 경우 -->
      <% } else { %>
        <div class="project-description">
          <% if (project.details && typeof project.details.description === 'string') { %>
            <p><%= project.details.description %></p>
          <% } else if (typeof project.description === 'string') { %>
            <p><%= project.description %></p>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
